{
  "project_name": "Mi Salud FdA",
  "theme": "light",
  "archetype": "Organic & Earthy",
  "colors": {
    "background": "#F9F8F6",
    "surface": "#FFFFFF",
    "primary": "#E07A5F",
    "primary_light": "#F2B8A7",
    "secondary": "#2A433A",
    "accent": "#819E8E",
    "text_primary": "#1F2321",
    "text_secondary": "#5C6B64",
    "border": "#E5E1DA",
    "success": "#4CAF50",
    "error": "#E53935",
    "card_background": "#FFFFFF"
  },
  "typography": {
    "font_family_heading": "Outfit, sans-serif",
    "font_family_body": "Manrope, sans-serif",
    "h1": "text-4xl font-bold tracking-tight text-[#2A433A]",
    "h2": "text-2xl font-semibold tracking-tight text-[#2A433A]",
    "h3": "text-xl font-semibold text-[#1F2321]",
    "body": "text-base text-[#5C6B64] leading-relaxed",
    "label": "text-sm font-medium tracking-wide uppercase text-[#819E8E]"
  },
  "layout_and_spacing": {
    "screen_padding": "px-6 pt-10 pb-6",
    "card_padding": "p-6",
    "gap": "gap-6",
    "border_radius": {
      "sm": "rounded-lg",
      "md": "rounded-xl",
      "lg": "rounded-2xl",
      "xl": "rounded-[32px]"
    },
    "shadows": {
      "soft": "shadow-[0_4px_20px_rgba(42,67,58,0.06)]",
      "floating": "shadow-[0_8px_32px_rgba(42,67,58,0.1)]"
    }
  },
  "components": {
    "bottom_tab_bar": {
      "background": "#FFFFFF",
      "active_tint": "#E07A5F",
      "inactive_tint": "#819E8E",
      "style": "Border-top with subtle shadow, slightly taller for modern feel, icon + label."
    },
    "contextual_widget": {
      "background": "#2A433A",
      "text_color": "#FFFFFF",
      "style": "Large rounded card (rounded-3xl), generous padding (p-8). Used for 'Next Appointment' or 'Welcome Back'."
    },
    "quick_action_button": {
      "background": "#F9F8F6",
      "style": "Square or squircle (rounded-2xl) card, icon on top, text below. Drop soft shadow. Text should be small, centered."
    },
    "appointment_card": {
      "background": "#FFFFFF",
      "border": "1px solid #E5E1DA",
      "style": "Row layout with Doctor Avatar (rounded-full), Name, Speciality, Time/Date badge. Primary action button 'Join Video' or 'Reschedule'."
    },
    "promo_banner": {
      "style": "Horizontal scrollable card, Image background with subtle dark overlay to keep text legible. rounded-2xl."
    }
  },
